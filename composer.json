{
  "name": "stateforge/scenario-laravel",
  "description": "Laravel adapter for Stateforge Scenario Core – declarative, attribute-driven scenario execution for reproducible application state.",
  "type": "library",
  "keywords": [
    "testing",
    "phpunit",
    "fixtures",
    "scenario",
    "state",
    "test-data",
    "laravel"
  ],
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Christina Koenig",
      "email": "christina.koenig@looriva.de",
      "role": "lead"
    }
  ],
  "homepage": "https://github.com/laloona/scenario-laravel",
  "support": {
    "issues": "https://github.com/laloona/scenario-laravel/issues",
    "source": "https://github.com/laloona/scenario-laravel"
  },
  "require": {
    "php": ">=8.2",
    "stateforge/scenario-core": "^1.1@dev",
    "laravel/framework": "^12.0",
    "symfony/process": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "Stateforge\\Scenario\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stateforge\\Scenario\\Laravel\\Tests\\Unit\\": "tests/unit/"
    },
    "classmap": [
      "tests/files"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5.50 || ^12.5.22 || ^13.1.6",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.60",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stateforge\\Scenario\\Laravel\\ScenarioLaravelServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-main": "1.1-dev"
    }
  }
}
