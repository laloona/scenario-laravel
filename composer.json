{
  "name": "scenario/laravel",
  "description": "Laravel adapter for Scenario Core – declarative, attribute-driven scenario execution for reproducible application state.",
  "type": "symfony-bundle",
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Christina Koenig",
      "email": "christina.koenig@looriva.de",
      "role": "lead"
    }
  ],
  "require": {
    "php": ">=8.2",
    "scenario/core": "dev-main",
    "laravel/framework": "^12.0",
    "symfony/process": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "Scenario\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Scenario\\Laravel\\Tests\\Unit\\": "tests/unit/"
    },
    "classmap": [
      "tests/files"
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.60",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Scenario\\Laravel\\ScenarioLaravelServiceProvider"
      ]
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:laloona/scenario-core.git"
    }
  ]
}
